{
  "info": {
    "name": "Milkman Backend API",
    "description": "Complete Postman collection covering Milkman backend APIs including auth, CRUD, checkout flows, and API docs endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "a4d6d6f7-4f54-4b0d-9f0f-4c5f4fd0b231"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "1" },
    { "key": "categoryId", "value": "1" },
    { "key": "productId", "value": "1" },
    { "key": "subscriptionId", "value": "1" },
    { "key": "subscriberId", "value": "1" },
    { "key": "orderId", "value": "1" },
    { "key": "orderItemId", "value": "1" }
  ],
  "item": [
