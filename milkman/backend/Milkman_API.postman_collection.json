{
    "info": {
        "name": "Milkman Backend API",
        "description": "Postman collection for all API endpoints found in the Django backend.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
        "_postman_id": "5f8dfb9f-1f97-4bde-8f9a-2a493eeea4e2"
    },
    "variable": [{
            "key": "baseUrl",
            "value": "http://127.0.0.1:8000"
        },
        {
            "key": "token",
            "value": ""
        },
        {
            "key": "userId",
            "value": "1"
        },
        {
            "key": "categoryId",
            "value": "1"
        },
        {
            "key": "productId",
            "value": "1"
        },
        {
            "key": "subscriptionId",
            "value": "1"
        },
        {
            "key": "subscriberId",
            "value": "1"
        },
        {
            "key": "orderId",
            "value": "1"
        },
        {
            "key": "orderItemId",
            "value": "1"
        }
    ],
    "item": [{
            "name": "User",
            "item": [{
                    "name": "Register User",
                    "request": {
                        "method": "POST",
                        "header": [{
                            "key": "Content-Type",
                            "value": "application/json"
                        }],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"username\": \"john\",\n  \"email\": \"john@example.com\",\n  \"password\": \"123456\",\n  \"age\": 25,\n  \"gender\": \"male\",\n  \"phone\": \"9876543210\",\n  \"address\": \"Some street\"\n}"
                        },
                        "url": "{{baseUrl}}/user/"
                    }
                },
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "header": [{
                            "key": "Content-Type",
                            "value": "application/json"
                        }],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"123456\"\n}"
                        },
                        "url": "{{baseUrl}}/user/login/"
                    },
                    "event": [{
                        "listen": "test",
                        "script": {
                            "type": "text/javascript",
                            "exec": [
                                "const data = pm.response.json();",
                                "if (data.token) {",
                                "  pm.collectionVariables.set('token', data.token);",
                                "}"
                            ]
                        }
                    }]
                },
                {
                    "name": "Logout",
                    "request": {
                        "method": "POST",
                        "auth": {
                            "type": "bearer",
                            "bearer": [{
                                "key": "token",
                                "value": "{{token}}",
                                "type": "string"
                            }]
                        },
                        "url": "{{baseUrl}}/user/logout/"
                    }
                },
                {
                    "name": "List Users",
                    "request": {
                        "method": "GET",
                        "auth": {
                            "type": "bearer",
                            "bearer": [{
                                "key": "token",
                                "value": "{{token}}",
                                "type": "string"
                            }]
                        },
                        "url": "{{baseUrl}}/user/"
                    }
                },
                {
                    "name": "Get User By ID",
                    "request": {
                        "method": "GET",
                        "auth": {
                            "type": "bearer",
                            "bearer": [{
                                "key": "token",
                                "value": "{{token}}",
                                "type": "string"
                            }]
                        },
                        "url": "{{baseUrl}}/user/{{userId}}/"
                    }
                },
                {
                    "name": "Update User",
                    "request": {
                        "method": "PUT",
                        "auth": {
                            "type": "bearer",
                            "bearer": [{
                                "key": "token",
                                "value": "{{token}}",
                                "type": "string"
                            }]
                        },
                        "header": [{
                            "key": "Content-Type",
                            "value": "application/json"
                        }],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"username\": \"john_updated\",\n  \"email\": \"john_updated@example.com\",\n  \"password\": \"123456\",\n  \"age\": 26,\n  \"gender\": \"male\",\n  \"phone\": \"9876543210\",\n  \"address\": \"Updated address\"\n}"
                        },
                        "url": "{{baseUrl}}/user/{{userId}}/"
                    }
                },
                {
                    "name": "Delete User",
                    "request": {
                        "method": "DELETE",
                        "auth": {
                            "type": "bearer",
                            "bearer": [{
                                "key": "token",
                                "value": "{{token}}",
                                "type": "string"
                            }]
                        },
                        "url": "{{baseUrl}}/user/{{userId}}/"
                    }
                }
            ]
        },
