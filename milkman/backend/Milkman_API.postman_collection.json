      "name": "API Docs",
      "item": [
        {
          "name": "Swagger UI",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/swagger/"
          }
        },
        {
          "name": "OpenAPI Schema",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/schema/"
          }
        },
        {
          "name": "ReDoc",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/redoc/"
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john\",\n  \"email\": \"john@example.com\",\n  \"password\": \"123456\",\n  \"age\": 25,\n  \"gender\": \"male\",\n  \"phone\": \"9876543210\",\n  \"address\": \"Some street\"\n}"
            },
            "url": "{{baseUrl}}/user/"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/user/login/"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.token) {",
                  "  pm.collectionVariables.set('token', data.token);",
                  "}",
                  "if (data.user_id) {",
                  "  pm.collectionVariables.set('userId', data.user_id.toString());",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/user/logout/"
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/user/"
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/user/{{userId}}/"
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_updated\",\n  \"email\": \"john_updated@example.com\",\n  \"password\": \"123456\",\n  \"age\": 26,\n  \"gender\": \"male\",\n  \"phone\": \"9876543210\",\n  \"address\": \"Updated address\"\n}"
            },
            "url": "{{baseUrl}}/user/{{userId}}/"
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/user/{{userId}}/"
          }
        },
        {
          "name": "List Admin Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/user/admin-users/"
          }
        }
      ]
